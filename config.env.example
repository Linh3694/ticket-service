# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/wellspring_tickets
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=wellspring_tickets
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration (đồng bộ users từ Frappe)
REDIS_HOST=172.16.20.120
REDIS_PORT=6379
REDIS_PASSWORD=breakpoint

# Redis User Events Channel
REDIS_USER_CHANNEL=user_events

# Feature flags for user sync
ENABLE_USER_REDIS_EVENTS=true
DEBUG_USER_EVENTS=1
DEBUG_WEBHOOK=1

# JWT Configuration (for fallback local verification)
JWT_SECRET=breakpoint

# Server Configuration
PORT=5001
SERVICE_NAME=ticket-service

# CORS Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://wis.wellspring.edu.vn,https://api-dev.wellspring.edu.vn,https://wis-staging.wellspring.edu.vn,https://admin.sis.wellspring.edu.vn

# Frappe API Configuration (PRIMARY AUTH METHOD)
FRAPPE_API_URL=https://admin.sis.wellspring.edu.vn
FRAPPE_API_KEY=your_frappe_api_key_here
FRAPPE_API_SECRET=your_frappe_api_secret_here
FRAPPE_API_TOKEN=your_frappe_api_token_here
TEST_FRAPPE_TOKEN=your_test_frappe_token_here

# Authentication Configuration
AUTH_MODE=frappe_api  # 'frappe_api' or 'local_jwt'
AUTH_TIMEOUT=5000     # Timeout for Frappe API calls (ms)

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=support@wellspring.edu.vn

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt,zip,mp4,mov,avi,webm,3gp

# File Compression Configuration
# Image compression (using sharp)
COMPRESS_IMAGES=true
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
IMAGE_QUALITY=80
MIN_SIZE_TO_COMPRESS=512000

# Video compression (requires ffmpeg installed on server)
COMPRESS_VIDEOS=false
VIDEO_MAX_WIDTH=1280
VIDEO_CRF=28
VIDEO_PRESET=fast

# Notification Service Configuration
# Phase 3 — ticket → notification-service (HTTP) + Stream envelope
# NOTIFICATION_SERVICE_URL — base URL notification-service (port 5004), không trùng PORT ticket.
NOTIFICATION_SERVICE_URL=http://127.0.0.1:5004
NOTIFICATION_SERVICE_API_KEY=your_notification_service_api_key

# Gọi Frappe song song với stream (true = vẫn POST Frappe khi cần; false = chỉ stream/HTTP)
TICKET_PARALLEL_FRAPPE_NOTIFY=true

# Gửi Expo trực tiếp từ ticket (legacy); false = chỉ qua notification-service / stream
TICKET_USE_EXPO_DIRECT_PUSH=false

# Service Integration
ENABLE_NOTIFICATION_INTEGRATION=true

# Gửi email ticket trực tiếp tới email-service (rollback). false = bật legacy axios. Mặc định/unset = stream → notification-service
TICKET_DISABLE_DIRECT_EMAIL=

# Email Service Configuration (legacy trực tiếp khi TICKET_DISABLE_DIRECT_EMAIL=false; không gắn với stream)
EMAIL_SERVICE_URL=http://localhost:5030

# Redis Channels for service communication
REDIS_NOTIFICATION_CHANNEL=notification_events
REDIS_TICKET_CHANNEL=ticket_events

# Phase 2 — song song Pub/Sub + Streams
EVENT_BUS_MODE=both
EVENT_BUS_STREAM_PREFIX=events
EVENT_BUS_STREAM_MAXLEN=100000

# Logging
LOG_LEVEL=info

# Email ticket
EMAIL_USER=your_email@wellspring.edu.vn
TENANT_ID=your_tenant_id_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here